# Dependencies
node_modules/
package-lock.json
**/package-lock.json

# Python cache
__pycache__/
**/__pycache__/

# Build output
dist/

# Environment — never commit secrets
.env

# TypeScript build info
*.tsbuildinfo
*.js.map

# Developable contract bundle is tracked; exclude only machine-local config
.developable/config.json

# Terraform — provider cache and sensitive variable files
.terraform/
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfvars.json
terraform/*.tfstate
terraform/*.tfstate.backup

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Prisma generated client (regenerated on install)
prisma/generated/
